# Environment variables for the @gaia/db package and the Supabase CLI.
#
# These are read at CLI / migration time, NOT by application code at runtime.
# Application env vars live in each app's own .env.example.

# =============================================================================
# Supabase CLI - third-party auth config (packages/db/supabase/config.toml)
# =============================================================================
# Clerk frontend API host (no scheme, no path). Supabase fetches the JWKS
# from https://<this>/.well-known/jwks.json to verify Clerk-issued JWTs.
# Production: clerk.cropautonomy.com
# Local dev:  <dev-instance>.accounts.dev
CLERK_FRONTEND_API_DOMAIN=

# =============================================================================
# Optional: connection target for `supabase db push` / `db diff`
# =============================================================================
# Linked project is normally configured via `supabase link --project-ref <ref>`
# (creates .supabase/config.json). These env vars override it for CI:
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=
