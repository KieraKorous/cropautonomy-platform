# =============================================================================
# API - REQUIRED
# =============================================================================
# Base URL of services/api. The lead form POSTs to ${NEXT_PUBLIC_API_URL}/v1/leads.
# Local dev:  http://localhost:8080
# Production: https://api.cropautonomy.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# Analytics - OPTIONAL
# =============================================================================
# PostHog client-side instrumentation. Not yet wired in source; set when the
# public-site event tracking lands (see queueing-email-analytics.md).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
