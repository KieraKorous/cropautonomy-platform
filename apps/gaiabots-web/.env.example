# =============================================================================
# Supabase - REQUIRED for lead capture
# =============================================================================
# Service-role credential used by @gaia/leads to insert into public_leads.
# Bypasses RLS - NEVER expose to the browser. Find under Project Settings ->
# API in the Supabase dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Override the destination table for lead inserts (defaults to public_leads).
SUPABASE_LEADS_TABLE=public_leads

# =============================================================================
# Resend - REQUIRED for lead notification emails
# =============================================================================
# Without these the /api/leads endpoint will reject submissions: lead capture
# treats Supabase persistence AND Resend notification as both required.
RESEND_API_KEY=
LEADS_NOTIFY_TO=
LEADS_NOTIFY_FROM=GaiaBots <updates@gaiabots.ai>

# =============================================================================
# Analytics - OPTIONAL
# =============================================================================
# PostHog client-side instrumentation. Not yet wired in source; set when the
# public-site event tracking lands (see queueing-email-analytics.md).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
