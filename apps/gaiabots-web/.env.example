# =============================================================================
# API - REQUIRED
# =============================================================================
# Base URL of services/api. The lead form POSTs to ${NEXT_PUBLIC_API_URL}/v1/leads.
# Local dev:  http://localhost:8080
# Production: https://api.cropautonomy.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# Analytics - OPTIONAL
# =============================================================================
# PostHog client-side instrumentation via @gaia/analytics. Leave the key blank to
# disable analytics (capture() becomes a no-op); set it to emit public-site events
# (public_page_viewed, public_cta_clicked, lead_form_*). See queueing-email-analytics.md.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
