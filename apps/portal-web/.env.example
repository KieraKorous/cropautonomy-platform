# =============================================================================
# Mapbox - REQUIRED
# =============================================================================
# Mapbox is the chosen map provider for CropAutonomy. The dashboard and any
# other map surfaces will not render without this set.
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# =============================================================================
# Supabase - REQUIRED
# =============================================================================
# Server-side (service role). Used by @gaia/db/server in route handlers,
# server actions, and pg-boss workers. Bypasses RLS - NEVER expose to the
# browser. Find under Project Settings -> API in the Supabase dashboard.
#
# ALL Postgres reads/writes from the browser must go through portal API
# routes that use this credential. The browser does NOT get a Supabase
# database client - see docs/architecture/database-schema.md § Client posture.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser-side (publishable / anon key). Used ONLY by @gaia/realtime for
# broadcast channel subscriptions and by Supabase Storage signed-URL fetches.
# NOT a database client - data access in the browser goes through API routes.
# Safe to expose; RLS is the backstop.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# Clerk - REQUIRED
# =============================================================================
# Identity provider. The portal hosts Clerk's sign-in/sign-up routes (primary
# domain). See docs/architecture/authentication-and-tenancy.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Webhook signing secret. Verifies Clerk -> portal webhooks (user.created,
# user.updated, etc.) that mirror identity into public.users and patch
# active_org_id into Clerk publicMetadata.
CLERK_WEBHOOK_SECRET=

# Clerk frontend API domain (no scheme, no path). Supabase fetches the JWKS
# from https://<this>/.well-known/jwks.json to verify Clerk-issued JWTs.
# Production: clerk.cropautonomy.com
# Local dev:  <dev-instance>.accounts.dev
CLERK_FRONTEND_API_DOMAIN=

# Routing - keep in sync with Clerk dashboard "paths" config.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# =============================================================================
# pg-boss (background workers) - REQUIRED when worker code runs in this app
# =============================================================================
# Direct Postgres connection string for pg-boss. Use the connection pooler
# in "session" mode (port 5432) for the worker process - NOT the transaction
# pooler (6543), which breaks pg-boss's LISTEN/NOTIFY.
# Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=

# =============================================================================
# Analytics - OPTIONAL
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
