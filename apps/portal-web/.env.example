# =============================================================================
# Mapbox - REQUIRED
# =============================================================================
# Mapbox is the chosen map provider for CropAutonomy. The dashboard and any
# other map surfaces will not render without this set.
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# =============================================================================
# Supabase - server-side service role
# =============================================================================
# REQUIRED only for the /api/webhooks/clerk receiver, which mirrors Clerk
# identity into public.users. All other data access goes through services/api
# (see docs/architecture/api-architecture.md). When the Clerk webhook moves
# to services/api, these two vars come out of portal-web entirely.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Supabase - browser anon key
# =============================================================================
# Used by @gaia/realtime for broadcast channel SUBSCRIBE and by Supabase
# Storage signed-URL fetches. Not a database client. Safe to expose.
# Required for the Live page (camera roster + WebRTC signaling).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# WebRTC ICE - Live page
# =============================================================================
# Viewer-side peer connections for the Live page. STUN-only by default; set
# TURN when supervisors sit behind restrictive NAT. STUN is comma-separated.
# NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
# NEXT_PUBLIC_TURN_URL=turns:turn.example.com:5349
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# =============================================================================
# API base - REQUIRED
# =============================================================================
# services/api at api.cropautonomy.com. The portal's UI and any RSC fetches
# call this for tenant data — never @gaia/db/server directly.
# Production: https://api.cropautonomy.com
# Local dev:  http://localhost:8080
# Name must match the build pipeline (.github/workflows/deploy.yml + the portal
# Dockerfile inline this as a build arg). NEXT_PUBLIC_* is baked at build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# =============================================================================
# Clerk - REQUIRED
# =============================================================================
# Identity provider. The portal hosts Clerk's sign-in/sign-up routes (primary
# domain). See docs/architecture/authentication-and-tenancy.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Webhook signing secret. Verifies Clerk -> portal webhooks (user.created,
# user.updated, etc.) that mirror identity into public.users and patch
# active_org_id into Clerk publicMetadata.
CLERK_WEBHOOK_SECRET=

# Clerk frontend API domain (no scheme, no path). Supabase fetches the JWKS
# from https://<this>/.well-known/jwks.json to verify Clerk-issued JWTs.
# Production: clerk.cropautonomy.com
# Local dev:  <dev-instance>.accounts.dev
CLERK_FRONTEND_API_DOMAIN=

# Routing - keep in sync with Clerk dashboard "paths" config.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# =============================================================================
# pg-boss (background workers) - REQUIRED when worker code runs in this app
# =============================================================================
# Direct Postgres connection string for pg-boss. Use the connection pooler
# in "session" mode (port 5432) for the worker process - NOT the transaction
# pooler (6543), which breaks pg-boss's LISTEN/NOTIFY.
# Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=

# =============================================================================
# Analytics - OPTIONAL
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
