# =============================================================================
# Portal API base
# =============================================================================
# Field PWA POSTs reserve/finalize/proxy-publish calls to the portal API.
# Production: https://app.cropautonomy.com
# Local dev:  http://app.lvh.me:3002 (cookie must be scoped to .lvh.me)
VITE_PORTAL_API_BASE=http://app.lvh.me:3002

# =============================================================================
# Clerk (satellite domain — primary lives in portal-web)
# =============================================================================
# See docs/architecture/authentication-and-tenancy.md § Cross-Surface SSO.
# A signed-out user is redirected to VITE_CLERK_SIGN_IN_URL on the primary
# domain, then sent back here after auth.
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_SATELLITE_DOMAIN=field.lvh.me:5173
VITE_CLERK_SIGN_IN_URL=http://app.lvh.me:3002/sign-in

# =============================================================================
# Supabase (anon key for realtime subscribe; publishes go through the portal)
# =============================================================================
# Used for the realtime SUBSCRIBE path only (WebRTC signaling on the
# capture-session-signal channel). Publishes go via the portal proxy until
# the Clerk -> Supabase JWT bridge is wired.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# WebRTC ICE configuration
# =============================================================================
# Comma-separated STUN URLs (default below works without setup).
# v0 is STUN-only; live preview may fail behind symmetric NAT until TURN
# is provisioned. Add VITE_TURN_URL + credentials to flip on TURN later.
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
