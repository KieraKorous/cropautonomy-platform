# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=development

# =============================================================================
# Postgres - REQUIRED
# =============================================================================
# Direct Postgres connection string for pg-boss. Use the connection pooler in
# "session" mode (port 5432) - NOT the transaction pooler (6543), which breaks
# pg-boss's LISTEN/NOTIFY.
# Supabase: Project Settings -> Database -> Connection string -> URI.
DATABASE_URL=
