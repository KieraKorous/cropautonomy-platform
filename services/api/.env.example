# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins. The defaults cover local dev
# for portal-web (3002), marketing apps (3000/3001), and field-web (5173).
# Production overrides with the public origins:
#   https://app.cropautonomy.com,https://field.cropautonomy.com,https://cropautonomy.com,https://gaiabots.ai
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173

# =============================================================================
# Supabase - REQUIRED
# =============================================================================
# Service-role credential. This is the ONLY process besides services/workers
# that holds the service role key. Bypasses RLS - never expose in any client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=public_leads

# =============================================================================
# Resend - REQUIRED for lead notification emails
# =============================================================================
RESEND_API_KEY=
LEADS_NOTIFY_TO=
LEADS_NOTIFY_FROM=CropAutonomy <updates@cropautonomy.com>

# =============================================================================
# Clerk - REQUIRED
# =============================================================================
# Secret key authenticates Clerk session tokens server-side. Publishable key
# is needed by @clerk/backend to resolve the Frontend API URL. Both are at
# Clerk dashboard > API Keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional: JWKS host (e.g. clerk.cropautonomy.com). Used by Supabase to
# verify Clerk JWTs for realtime/storage — services/api uses @clerk/backend's
# built-in JWKS so this is informational here.
CLERK_FRONTEND_API_DOMAIN=

# =============================================================================
# Build metadata - injected by CI
# =============================================================================
# Surfaces via GET /v1/_meta/build for deploy verification.
BUILD_COMMIT=dev
BUILD_VERSION=0.1.0
# BUILD_TIME defaults to the process start time if unset.
