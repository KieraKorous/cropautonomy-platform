{
    "name": "@gaia/api",
    "version": "0.1.0",
    "private": true,
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/index.js",
        "start": "node --env-file=.env dist/index.js",
        "lint": "tsc --noEmit",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@clerk/backend": "1.20.0",
        "@fastify/cors": "10.0.1",
        "@gaia/db": "workspace:*",
        "@gaia/domain": "workspace:*",
        "@gaia/leads": "workspace:*",
        "@gaia/realtime": "workspace:*",
        "@gaia/workers": "workspace:*",
        "@supabase/supabase-js": "2.87.0",
        "fastify": "5.1.0",
        "fastify-plugin": "5.0.1",
        "pg-boss": "10.1.6",
        "uuidv7": "1.0.2",
        "zod": "3.23.8"
    },
    "devDependencies": {
        "@types/node": "24.10.1",
        "esbuild": "^0.28.0",
        "pino-pretty": "11.2.2",
        "tsx": "4.19.2",
        "typescript": "5.9.3"
    }
}