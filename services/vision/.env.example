# services/vision configuration.
# Copy to .env (or .env.local) and fill in secrets. Never commit real keys.

# Server
VISION_HOST=0.0.0.0
VISION_PORT=8080
VISION_LOG_LEVEL=info

# PlantNet — https://my.plantnet.org/ → register → API key.
# Free tier is 500 requests/day, enough for early backyard testing.
PLANTNET_API_KEY=
PLANTNET_API_BASE_URL=https://my-api.plantnet.org
PLANTNET_PROJECT=all
PLANTNET_DEFAULT_ORGANS=auto

# Optional: max image size accepted by the inference endpoint, bytes.
# Larger images are rejected with 413. Default 20 MB.
VISION_MAX_IMAGE_BYTES=20971520

# Optional: outbound HTTP timeout to provider APIs, seconds.
VISION_PROVIDER_TIMEOUT_SECONDS=30
