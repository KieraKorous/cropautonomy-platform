{
  "name": "gaia-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @gaia/cropautonomy-web --filter @gaia/gaiabots-web dev",
