{
  "name": "gaia-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @gaia/cropautonomy-web --filter @gaia/gaiabots-web --filter @gaia/portal-web --filter @gaia/api dev",
    "dev:cropautonomy": "pnpm --filter @gaia/cropautonomy-web dev",
    "dev:gaiabots": "pnpm --filter @gaia/gaiabots-web dev",
    "dev:portal": "pnpm --filter @gaia/portal-web dev",
    "dev:field": "pnpm --filter @gaia/field-web dev",
    "dev:api": "pnpm --filter @gaia/api dev",
    "dev:workers": "pnpm --filter @gaia/workers dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
